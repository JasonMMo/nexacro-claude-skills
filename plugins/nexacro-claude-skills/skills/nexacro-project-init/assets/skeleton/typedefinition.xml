    <Service prefixid="font" type="resource" url="./_resource_/_font_/" version="0" communicationversion="0" include_subdir="false"/>
    <Service prefixid="Base" type="form" cachelevel="session" url="./Base/" version="0" communicationversion="0" include_subdir="false"/>
    <Service prefixid="{{FORM_PREFIX}}" type="form" cachelevel="session" url="./{{FORM_PREFIX}}/" version="0" communicationversion="0" include_subdir="false"/>
  </Services>
  <Protocols/>
  <Update>
    <Os name="Windows" url="./" timeout="30" retry="3" autoupdate="auto" updatetype="server"/>
  </Update>
  <Deploy>
    <Os name="Windows"/>
  </Deploy>
</TypeDefinition>
