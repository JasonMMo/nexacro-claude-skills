{
  "name": "nexacro-claude-skills",
  "version": "1.0.0",
  "description": "Claude Code skills for Nexacro platform development",
  "author": "JasonMMo",
  "repository": "https://github.com/JasonMMo/nexacro-claude-skills",
  "license": "MIT",
  "skills": [
    {
      "name": "nexacro-build",
      "description": "Automates Nexacro XFDL source build and deployment operations",
      "triggers": [
        "nexacro 빌드",
        "xfdl 빌드",
        "nexacrodeploy 실행",
        "generate 해줘",
        "deploy 해줘",
        "넥사크로 빌드"
      ],
      "type": "automation",
      "category": "development"
    },
    {
      "name": "nexacro-webflux-port",
      "description": "Playbook for porting Spring Boot/MVC Nexacro modules (xapi/xeni/uiadapter) to Spring WebFlux. Covers classpath shim, ServletProvider, multipart dispatch, paramOf equivalence, WebFilter bypass, ResultHandler ordering, stub shim limitations, base-path and static resource mapping.",
      "triggers": [
        "webflux 전환",
        "reactive 로 바꿔",
        "서블릿 제거",
        "nexacro webflux",
        "xapi 포팅",
        "xeni 포팅",
        "uiadapter 포팅",
        "HttpServletRequest 제거"
      ],
      "type": "reference",
      "category": "migration"
    }
  ],
  "requirements": {
    "node": ">=16.0.0",
    "claude-code": ">=1.0.0"
  },
  "installation": {
    "marketplace": {
      "command": "/plugin marketplace add JasonMMo/nexacro-claude-skills"
    },
    "skill": {
      "command": "/plugin install nexacro-build@JasonMMo/nexacro-claude-skills"
    },
    "manual": {
      "clone": "git clone https://github.com/JasonMMo/nexacro-claude-skills.git",
      "copy": "cp -r nexacro-claude-skills/skills/nexacro-build ~/.claude/skills/"
    }
  },
  "keywords": [
    "nexacro",
    "xfdl",
    "build",
    "deploy",
    "automation",
    "korean-support"
  ],
  "icon": "https://github.com/JasonMMo/nexacro-claude-skills/raw/main/icon.png",
  "screenshots": [
    "https://github.com/JasonMMo/nexacro-claude-skills/raw/main/screenshots/basic-usage.png",
    "https://github.com/JasonMMo/nexacro-claude-skills/raw/main/screenshots/advanced.png"
  ]
}